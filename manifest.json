{
  "manifest_version": 3,
  "name": "Hold Space Dictation",
  "description": "Hold Space in an editable field to dictate with local Whisper.",
  "version": "0.1.0",
  "key": "",
  "permissions": ["nativeMessaging", "notifications", "storage"],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "128": "icons/icon.svg"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_title": "Hold Space Dictation",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/icon.svg"
    }
  }
}
